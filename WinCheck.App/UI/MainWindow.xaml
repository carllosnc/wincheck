<Window x:Class="WinCheck.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinCheck">

    <Grid Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="12,12,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="12,8,12,8">
                <StackPanel>
                    <TextBlock Text="NAVIGATION" FontSize="10" FontWeight="Bold"
                               Foreground="{ThemeResource TextFillColorDisabledBrush}"
                               Margin="0,0,0,12" />
                    <Button x:Name="NavProcesses" Click="OnNavProcesses"
                            HorizontalAlignment="Stretch" Height="36" Margin="0,0,0,4"
                            Style="{ThemeResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE756;" FontSize="14" Margin="8,0,8,0" />
                            <TextBlock Text="Processes" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavInfo" Click="OnNavInfo"
                            HorizontalAlignment="Stretch" Height="36" Margin="0,0,0,4"
                            Style="{ThemeResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE946;" FontSize="14" Margin="8,0,8,0" />
                            <TextBlock Text="System Info" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavStartup" Click="OnNavStartup"
                            HorizontalAlignment="Stretch" Height="36" Margin="0,0,0,4"
                            Style="{ThemeResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE768;" FontSize="14" Margin="8,0,8,0" />
                            <TextBlock Text="Startup" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavDisk" Click="OnNavDisk"
                            HorizontalAlignment="Stretch" Height="36" Margin="0,0,0,4"
                            Style="{ThemeResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE8B7;" FontSize="14" Margin="8,0,8,0" />
                            <TextBlock Text="Disk" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavCleanup" Click="OnNavCleanup"
                            HorizontalAlignment="Stretch" Height="36" Margin="0,0,0,4"
                            Style="{ThemeResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" Margin="8,0,8,0" />
                            <TextBlock Text="Cleanup" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavPerformance" Click="OnNavPerformance"
                            HorizontalAlignment="Stretch" Height="36" Margin="0,0,0,4"
                            Style="{ThemeResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xEA3A;" FontSize="14" Margin="8,0,8,0" />
                            <TextBlock Text="Performance" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid x:Name="ProcessesView">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                            Padding="12" CornerRadius="6" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Spacing="12">
                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="14,10" Width="200">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="RAM" FontSize="12" FontWeight="Bold"
                                                   Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                        <TextBlock x:Name="RamPercent" FontSize="22" FontWeight="Bold"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                   VerticalAlignment="Center" Text="--" />
                                    </Grid>
                                    <ProgressBar x:Name="RamBar" Height="4" Margin="0,8,0,6" Value="0" />
                                    <TextBlock x:Name="RamLabel" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" Text="--" />
                                </StackPanel>
                            </Border>
                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="14,10" Width="200">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="CPU" FontSize="12" FontWeight="Bold"
                                                   Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                        <TextBlock x:Name="CpuPercent" FontSize="22" FontWeight="Bold"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                   VerticalAlignment="Center" Text="--" />
                                    </Grid>
                                    <ProgressBar x:Name="CpuBar" Height="4" Margin="0,8,0,6" Value="0" />
                                    <TextBlock x:Name="CpuLabel" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" Text="--" />
                                </StackPanel>
                            </Border>
                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="14,10" Width="200">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="DISK" FontSize="12" FontWeight="Bold"
                                                   Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                        <TextBlock x:Name="DiskPercent" FontSize="22" FontWeight="Bold"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                   VerticalAlignment="Center" Text="--" />
                                    </Grid>
                                    <ProgressBar x:Name="DiskBar" Height="4" Margin="0,8,0,6" Value="0" />
                                    <TextBlock x:Name="DiskLabel" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" Text="--" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.8*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="28" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Processes" FontSize="15" FontWeight="Bold"
                                           Foreground="{ThemeResource AccentFillColorDefaultBrush}" Margin="0,0,0,8" />

                                <TextBox x:Name="SearchBox" Grid.Row="1" TextChanged="OnSearchTextChanged"
                                         PlaceholderText="Search by name, company or PID..."
                                         VerticalAlignment="Center" Margin="0,0,0,8" />

                                <Border Grid.Row="2" Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,0,0,1"
                                        Padding="30,0,10,0">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="52" /><ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" /><ColumnDefinition Width="86" /><ColumnDefinition Width="58" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Type" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorDisabledBrush}" />
                                        <TextBlock Grid.Column="1" Text="Name" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorDisabledBrush}" />
                                        <TextBlock Grid.Column="2" Text="PID" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorDisabledBrush}" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="3" Text="Mem" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorDisabledBrush}" HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="4" Text="Thr" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorDisabledBrush}" HorizontalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <TreeView Grid.Row="3" x:Name="ProcessTree" SelectionMode="Single"
                                          ItemInvoked="OnProcessItemInvoked" HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                                Padding="12" CornerRadius="6" Margin="12,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Process Details" FontSize="15" FontWeight="Bold"
                                           Foreground="{ThemeResource AccentFillColorDefaultBrush}" Margin="0,0,0,8" />
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="DetailPanel" Margin="0,4,0,0">
                                        <TextBlock x:Name="DetailPlaceholder"
                                                   Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                                   FontSize="12" Text="Select a process in the tree..." Margin="0,4,0,0" />
                                        <Grid x:Name="DetailGrid" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="32" /><RowDefinition Height="32" />
                                                <RowDefinition Height="32" /><RowDefinition Height="32" />
                                                <RowDefinition Height="32" /><RowDefinition Height="32" />
                                                <RowDefinition Height="32" /><RowDefinition Height="32" />
                                                <RowDefinition Height="32" /><RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetailName" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="PID" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetailPid" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Type" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetailType" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Memory" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DetailMemory" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Threads" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DetailThreads" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Handles" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="DetailHandles" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Company" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="6" Grid.Column="1" x:Name="DetailCompany" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Description" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="7" Grid.Column="1" x:Name="DetailDesc" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Responding" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="8" Grid.Column="1" x:Name="DetailResponding" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />

                                            <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0">
                                                <TextBlock Text="Path" FontSize="11"
                                                           Foreground="{ThemeResource TextFillColorDisabledBrush}" />
                                                <TextBlock x:Name="DetailPath" FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="48" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                                <Button Grid.Row="2" x:Name="KillBtn" Background="#C50514" Foreground="White"
                                        Content="Kill Process" Click="OnKillProcess" IsEnabled="False"
                                        HorizontalAlignment="Left" Margin="0,8,0,0" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <ScrollViewer x:Name="InfoView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Processor" FontSize="14" FontWeight="Bold"
                                           Foreground="{ThemeResource AccentFillColorDefaultBrush}" Margin="0,0,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" /><ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" /><RowDefinition Height="30" />
                                        <RowDefinition Height="30" /><RowDefinition Height="30" />
                                        <RowDefinition Height="30" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="InfoCpuName" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Cores" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="InfoCpuCores" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Logical Procs" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="InfoCpuLogical" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Architecture" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="InfoCpuArch" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Usage" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="InfoCpuUsage" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Memory" FontSize="14" FontWeight="Bold"
                                           Foreground="{ThemeResource AccentFillColorDefaultBrush}" Margin="0,0,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" /><ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" /><RowDefinition Height="30" />
                                        <RowDefinition Height="30" /><RowDefinition Height="30" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Total" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="InfoRamTotal" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Used" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="InfoRamUsed" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Available" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="InfoRamAvail" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Load" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="InfoRamLoad" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Disk" FontSize="14" FontWeight="Bold"
                                           Foreground="{ThemeResource AccentFillColorDefaultBrush}" Margin="0,0,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" /><ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" /><RowDefinition Height="30" />
                                        <RowDefinition Height="30" /><RowDefinition Height="30" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Drive" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="InfoDiskDrive" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Total" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="InfoDiskTotal" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Free" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="InfoDiskFree" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="File System" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="InfoDiskFs" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Operating System" FontSize="14" FontWeight="Bold"
                                           Foreground="{ThemeResource AccentFillColorDefaultBrush}" Margin="0,0,0,12" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" /><ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" /><RowDefinition Height="30" />
                                        <RowDefinition Height="30" /><RowDefinition Height="30" />
                                        <RowDefinition Height="30" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="OS" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="InfoOsName" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Version" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="InfoOsVersion" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Build" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="InfoOsBuild" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Architecture" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="InfoOsArch" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Machine Name" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="InfoMachineName" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid x:Name="StartupView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Startup Programs" FontSize="14" FontWeight="Bold"
                                       Foreground="{ThemeResource AccentFillColorDefaultBrush}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" x:Name="StartupSearchBox"
                                     TextChanged="OnStartupSearchChanged"
                                     PlaceholderText="Search by name, command or source..."
                                     Margin="12,0" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <ComboBox x:Name="StartupFilter" SelectedIndex="0" Width="160"
                                          FontSize="12" Margin="0,0,8,0"
                                          SelectionChanged="OnStartupFilterChanged">
                                    <ComboBoxItem Content="All" Tag="All" />
                                    <ComboBoxItem Content="Registry" Tag="Registry" />
                                    <ComboBoxItem Content="Startup Folder" Tag="StartupFolder" />
                                    <ComboBoxItem Content="Scheduled Tasks" Tag="ScheduledTask" />
                                    <ComboBoxItem Content="Services" Tag="Service" />
                                    <ComboBoxItem Content="Store Apps" Tag="StoreApp" />
                                </ComboBox>
                                <Button Content="Scan" Click="OnScanStartup"
                                        Width="70" Height="28" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="StartupList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                                BorderThickness="0,0,0,1" Padding="0,6" Margin="0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Image Grid.Row="0" Grid.Column="0"
                                                       Source="{Binding IconSource}"
                                                       Width="20" Height="20" Stretch="Uniform"
                                                       VerticalAlignment="Top" Margin="0,2,8,0" />
                                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="12" Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    <Border CornerRadius="3" Padding="4,1" Margin="8,0,0,0"
                                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TypeLabel}" FontSize="9"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Grid.Row="1" Grid.Column="1"
                                                           FontSize="10" Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"
                                                           Text="{Binding Command}" />
                                                <TextBlock Grid.Row="2" Grid.Column="1"
                                                           FontSize="10" Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                                           TextTrimming="CharacterEllipsis" Margin="0,1,0,0"
                                                           Text="{Binding Description}"
                                                           Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}" />
                                                <StackPanel Grid.Row="0" Grid.Column="2"
                                                            Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Source}" FontSize="10"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                                    <CheckBox IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                              VerticalAlignment="Center"
                                                              Checked="OnToggleStartup"
                                                              Unchecked="OnToggleStartup"
                                                              Tag="{Binding}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid x:Name="DiskView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button x:Name="DiskBackBtn" Content="&#xE72B;" FontFamily="Segoe MDL2 Assets"
                                        FontSize="12" Width="32" Height="32" Click="OnDiskBack"
                                        IsEnabled="False" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <ComboBox x:Name="DriveSelector" Width="180" VerticalAlignment="Center"
                                          Margin="0,0,8,0" SelectionChanged="OnDriveChanged" />
                                <Button x:Name="ScanBtn" Content="Scan" Click="OnScanDisk"
                                        VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ComboBox x:Name="DiskSortMode" Width="100" VerticalAlignment="Center"
                                          SelectedIndex="0" SelectionChanged="OnDiskSortChanged">
                                    <ComboBoxItem Content="Size" />
                                    <ComboBoxItem Content="Name" />
                                    <ComboBoxItem Content="Files" />
                                </ComboBox>
                                <TextBlock x:Name="ScanStatus" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                            <TextBlock x:Name="BreadcrumbPath" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,0,4" Visibility="Collapsed" />
                            <Border x:Name="ScanProgress" Visibility="Collapsed"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="6" Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="ScanCurrentFolder" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,0,0,4" />
                                    <ProgressBar Grid.Row="1" x:Name="ScanFill" Height="4" Margin="0,0,0,6" IsIndeterminate="True" />
                                    <TextBlock Grid.Row="2" x:Name="ScanStats" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="FolderList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1" Padding="12,8" Margin="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <FontIcon Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                                      Glyph="&#xE8B7;" FontSize="16"
                                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                      VerticalAlignment="Center" Margin="0,0,10,0" />
                                            <Button Grid.Row="0" Grid.Column="1"
                                                    Content="{Binding Name}" FontSize="13"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Tag="{Binding}"
                                                    Click="OnFolderDrill"
                                                    Style="{StaticResource TextBlockButtonStyle}" />
                                            <FontIcon Grid.Row="0" Grid.Column="1"
                                                      Glyph="&#xE74D;" FontSize="12"
                                                      Foreground="Orange" HorizontalAlignment="Right"
                                                      VerticalAlignment="Center" Margin="0,0,6,0"
                                                      Visibility="{Binding CleanupVisibility}" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Path}" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                            <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                                        VerticalAlignment="Center" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding SizeFormatted}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                           HorizontalAlignment="Right" />
                                                <ProgressBar Width="150" Height="4" Value="{Binding Percentage}"
                                                             Foreground="{Binding BarBrush}"
                                                             Margin="0,4,0,0" HorizontalAlignment="Right" />
                                                <TextBlock Text="{Binding PercentageFormatted}" FontSize="10"
                                                           Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                                           HorizontalAlignment="Right" Margin="0,2,0,0" />
                                                <TextBlock FontSize="10"
                                                           Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                                           HorizontalAlignment="Right" Margin="0,2,0,0">
                                                    <Run Text="{Binding FileCount}" /><Run Text=" files, "/>
                                                    <Run Text="{Binding FolderCount}" /><Run Text=" folders"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="PerformanceView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Performance Tweaks" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                <TextBlock Text="Toggle Windows settings for maximum performance" FontSize="11"
                                           Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="Refresh" Click="OnNavPerformance"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PerfList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1" Padding="12,10" Margin="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <FontIcon Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                                      Glyph="&#xEA3A;" FontSize="18"
                                                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />

                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Description}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" FontSize="10"
                                                       Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                                       Margin="0,4,0,0" Visibility="{Binding HasStatusVisibility}">
                                                <Run Text="Status: " /><Run Text="{Binding Status}" />
                                            </TextBlock>

                                            <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                                        VerticalAlignment="Center" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding CurrentValue}" FontSize="11"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           HorizontalAlignment="Center" Margin="0,0,0,4" />
                                                <ToggleSwitch IsOn="{Binding IsEnabled, Mode=OneWay}"
                                                              Tag="{Binding}"
                                                              Toggled="OnPerfToggle" />
                                                <TextBlock Text="Restart required" FontSize="10"
                                                           Foreground="Orange" HorizontalAlignment="Center"
                                                           Margin="0,4,0,0"
                                                           Visibility="{Binding RebootVisibility}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock x:Name="PerfStatus" Grid.Row="1" FontSize="12"
                               Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                               VerticalAlignment="Bottom" Margin="0,0,0,8" />
                </Grid>

                <Grid x:Name="CleanupView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="CleanupAnalyzeBtn" Content="Analyze" Click="OnCleanupAnalyze"
                                    VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Button x:Name="CleanupRunBtn" Content="Clean" Click="OnCleanupRun"
                                    VerticalAlignment="Center" IsEnabled="False" Margin="0,0,8,0" />
                            <TextBlock x:Name="CleanupStatus" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="CleanupList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
                                            BorderThickness="0,0,0,1" Padding="12,10" Margin="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <CheckBox Grid.Row="0" Grid.RowSpan="4" Grid.Column="0"
                                                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                      VerticalAlignment="Center" Margin="0,0,10,0" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}" FontSize="13"
                                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Description}" FontSize="11"
                                                           Foreground="{ThemeResource TextFillColorDisabledBrush}"
                                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding CleanupSummary}" FontSize="11"
                                                               Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                               Visibility="{Binding SummaryVisibility}" />
                                                    <Button Content="Details" FontSize="10"
                                                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                            Background="Transparent" BorderThickness="0" Padding="0"
                                                            Click="OnCleanupToggleDetails"
                                                            Tag="{Binding}"
                                                            Visibility="{Binding HasDetailsVisibility}"
                                                            Margin="6,0,0,0" />
                                                </StackPanel>
                                                <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                                           Text="{Binding DetailsText}" FontSize="10"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           FontFamily="Consolas"
                                                           TextWrapping="Wrap" Margin="0,6,0,0"
                                                           Visibility="{Binding DetailsVisibility}" />
                                                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                                            VerticalAlignment="Center" Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding SizeFormatted}" FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding Status}" FontSize="11"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               HorizontalAlignment="Right" Margin="0,2,0,0"
                                                               Visibility="{Binding HasStatusVisibility}" />
                                                </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1"
                Padding="10,6" CornerRadius="6" Margin="12,4,12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE8A9;" FontSize="12"
                              Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                              VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock x:Name="WinCount" FontSize="12" FontWeight="Bold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center" Text="--" Margin="0,0,14,0" />
                    <FontIcon Glyph="&#xE91B;" FontSize="12"
                              Foreground="{ThemeResource TextFillColorDisabledBrush}"
                              VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock x:Name="ThirdCount" FontSize="12" FontWeight="Bold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center" Text="--" Margin="0,0,14,0" />
                    <TextBlock Text="Total" FontSize="11"
                               Foreground="{ThemeResource TextFillColorDisabledBrush}"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock x:Name="TotalCount" FontSize="12" FontWeight="Bold"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center" Text="--" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="AdminBadge" Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="3" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center"
                            Visibility="Collapsed">
                        <TextBlock x:Name="AdminBadgeText" FontSize="11"
                                   Foreground="White" Text="Administrator" />
                    </Border>
                    <Button x:Name="RestartAdminBtn" Content="Restart as Admin"
                            Click="OnRestartAsAdmin"
                            VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" />
                    <CheckBox x:Name="AutoToggle" Content="Live Reload"
                              VerticalAlignment="Center" Margin="0,0,12,0"
                              Checked="OnToggleAutoChanged" Unchecked="OnToggleAutoChanged" />
                    <Button x:Name="RefreshBtn" Content="Refresh (F5)" Click="OnRefresh"
                            VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock x:Name="LiveLabel"
                               Foreground="{ThemeResource TextFillColorDisabledBrush}"
                               FontSize="11" VerticalAlignment="Center" Text="" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="LoadingOverlay" Grid.RowSpan="2"
              Background="#88000000" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressRing x:Name="LoadingRingOverlay"
                              Width="64" Height="64"
                              Foreground="White"
                              IsActive="True" />
                <TextBlock x:Name="LoadingOverlayText"
                           Text="Loading..."
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
